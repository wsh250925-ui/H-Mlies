/* 个人页样式 */

/* 性别选择 */
.gender-options {
  display: flex;
  gap: 20rpx;
}
.gender-card {
  flex: 1;
  text-align: center;
  padding: 28rpx 16rpx;
  border-radius: 16rpx;
  border: 3rpx solid #e8e8e8;
  background: #fafafa;
  transition: all 0.2s;
}
.gender-card.active.male {
  border-color: var(--blue);
  background: var(--blue-light);
}
.gender-card.active.female {
  border-color: var(--purple);
  background: var(--purple-light);
}
.gender-icon {
  font-size: 56rpx;
  display: block;
  margin-bottom: 12rpx;
}
.gender-text {
  font-size: 30rpx;
  font-weight: 600;
  display: block;
}
.gender-sub {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
}
.gender-saved {
  text-align: center;
  margin-top: 16rpx;
  font-size: 26rpx;
}

/* 模块管理 */
.add-btn {
  font-size: 28rpx;
  color: var(--blue);
  font-weight: 500;
}
.module-row {
  display: flex;
  align-items: center;
  padding: 22rpx 12rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.module-row:last-child { border-bottom: none; }
.module-row-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}
.module-row-name {
  flex: 1;
  font-size: 30rpx;
}
.module-row-tag {
  font-size: 22rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}
.module-row-del {
  font-size: 26rpx;
  color: var(--red);
  padding: 8rpx 16rpx;
}

/* 设置行 */
.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 30rpx;
}
.setting-row:last-child { border-bottom: none; }
.setting-row.danger { color: var(--red); }
.arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.modal-box {
  width: 580rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx 28rpx;
}
.form-group {
  margin-bottom: 24rpx;
}
.form-label {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
}
.form-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.icon-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}
.icon-item {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  background: #f5f5f5;
  border-radius: 14rpx;
  border: 3rpx solid transparent;
  transition: all 0.2s;
}
.icon-item.active {
  border-color: var(--blue);
  background: var(--blue-light);
}
.modal-btns {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  margin-top: 24rpx;
}
.modal-btns .btn {
  width: 200rpx;
}

/* 关于 */
.about-text {
  font-size: 26rpx;
  color: #999;
  line-height: 2;
}
.about-text text {
  display: block;
}

/* 底部 */
.footer-text {
  text-align: center;
  padding: 48rpx 0 80rpx;
  color: #ccc;
  font-size: 26rpx;
}
