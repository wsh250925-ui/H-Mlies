/* 统计页样式 */

/* 戒色统计核心 */
.stats-hero {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}
.stats-hero-label {
  font-size: 28rpx;
  margin-bottom: 28rpx;
  opacity: 0.9;
}
.stats-hero-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}
.stats-hero-item {
  text-align: center;
  flex: 1;
}
.stats-hero-num {
  font-size: 56rpx;
  font-weight: 800;
  display: block;
  line-height: 1.2;
}
.stats-hero-sub {
  font-size: 22rpx;
  opacity: 0.8;
  display: block;
  margin-top: 6rpx;
}
.stats-hero-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.3);
}

/* 图表 */
.chart-canvas {
  width: 100%;
  height: 360rpx;
  margin-top: 16rpx;
}
.chart-empty {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 26rpx;
}

/* 健身统计 */
.fit-stats {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 0;
}
.fit-stat-item {
  text-align: center;
}
.fit-stat-num {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--blue);
  display: block;
}
.fit-stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

/* 自定义模块统计 */
.custom-stat-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.custom-stat-item:last-child { border-bottom: none; }
.custom-stat-name {
  width: 120rpx;
  font-size: 28rpx;
  font-weight: 500;
}
.custom-stat-bar-wrap {
  flex: 1;
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  margin: 0 20rpx;
  overflow: hidden;
}
.custom-stat-bar {
  height: 100%;
  background: var(--green);
  border-radius: 8rpx;
  min-width: 4rpx;
  transition: width 0.5s;
}
.custom-stat-count {
  width: 60rpx;
  text-align: right;
  font-size: 26rpx;
  color: #666;
}
