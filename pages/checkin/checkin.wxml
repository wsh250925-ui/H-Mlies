<!-- 打卡页 — 运动详情记录 -->
<view class="container">
  <view class="page-title">运动记录</view>
  <view class="page-date">记录每次运动的详情</view>

  <view class="card" wx:if="{{todayLogs.length > 0}}">
    <view class="card-title">🏃 今日运动</view>
    <view class="fit-log-item" wx:for="{{todayLogs}}" wx:key="index">
      <text class="fit-log-type">{{item.type}}</text>
      <text class="fit-log-dur">{{item.duration}}分钟</text>
    </view>
  </view>

  <view class="card">
    <view class="card-title">➕ 记录运动</view>
    <view class="form-group">
      <view class="form-label">运动类型</view>
      <view class="type-grid">
        <view class="type-item {{fitnessType === item ? 'active' : ''}}" wx:for="{{exerciseTypes}}" wx:key="*this" bindtap="selectType" data-type="{{item}}">{{item}}</view>
      </view>
    </view>
    <view class="form-group">
      <view class="form-label">时长（分钟）</view>
      <view class="duration-picker">
        <text class="dur-btn" bindtap="changeDur" data-d="-5">−5</text>
        <text class="dur-val">{{fitnessDuration}}</text>
        <text class="dur-unit">分钟</text>
        <text class="dur-btn" bindtap="changeDur" data-d="5">+5</text>
      </view>
      <view class="quick-durs">
        <text class="qd {{fitnessDuration===15?'active':''}}" bindtap="setDur" data-d="15">15</text>
        <text class="qd {{fitnessDuration===30?'active':''}}" bindtap="setDur" data-d="30">30</text>
        <text class="qd {{fitnessDuration===45?'active':''}}" bindtap="setDur" data-d="45">45</text>
        <text class="qd {{fitnessDuration===60?'active':''}}" bindtap="setDur" data-d="60">60</text>
        <text class="qd-unit">分钟</text>
      </view>
    </view>
    <button class="btn btn-primary btn-full" bindtap="saveLog">记录运动</button>
  </view>

  <view class="card">
    <view class="card-title">📊 本月汇总</view>
    <view class="fit-stats">
      <view class="fit-stat-item"><text class="fit-stat-num">{{monthDays}}</text><text class="fit-stat-label">运动天数</text></view>
      <view class="fit-stat-item"><text class="fit-stat-num">{{monthMins}}</text><text class="fit-stat-label">总分钟</text></view>
    </view>
  </view>
</view>
