/* 打卡页 — 运动记录 */
.page-title { font-size: 40rpx; font-weight: 700; margin-bottom: 8rpx; }
.page-date { font-size: 26rpx; color: #999; margin-bottom: 32rpx; }

/* 运动日志 */
.fit-log-item { display: flex; justify-content: space-between; padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.fit-log-item:last-child { border-bottom: none; }
.fit-log-type { font-size: 30rpx; font-weight: 500; }
.fit-log-dur { font-size: 28rpx; color: var(--blue); }

/* 表单 */
.form-group { margin-bottom: 28rpx; }
.form-label { font-size: 28rpx; font-weight: 600; margin-bottom: 16rpx; }
.type-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.type-item { padding: 12rpx 24rpx; background: #f5f5f5; border-radius: 20rpx; font-size: 26rpx; color: #666; }
.type-item.active { background: var(--blue); color: #fff; }

/* 时长选择 */
.duration-picker { display: flex; align-items: center; justify-content: center; padding: 8rpx 0; }
.dur-btn { width: 64rpx; height: 64rpx; border-radius: 50%; background: #f0f0f0; display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: 600; color: #666; }
.dur-val { font-size: 64rpx; font-weight: 700; margin: 0 12rpx; min-width: 80rpx; text-align: center; }
.dur-unit { font-size: 28rpx; color: #999; margin-right: 16rpx; }
.quick-durs { display: flex; gap: 12rpx; justify-content: center; margin-top: 16rpx; align-items: baseline; }
.qd { padding: 10rpx 22rpx; background: #f5f5f5; border-radius: 16rpx; font-size: 26rpx; color: #666; font-weight: 500; }
.qd.active { background: var(--blue-light); color: var(--blue); }
.qd-unit { font-size: 24rpx; color: #999; }
.btn-full { width: 100%; margin-top: 16rpx; }

/* 统计 */
.fit-stats { display: flex; justify-content: space-around; padding: 16rpx 0; }
.fit-stat-item { text-align: center; }
.fit-stat-num { font-size: 52rpx; font-weight: 700; color: var(--blue); display: block; }
.fit-stat-label { font-size: 24rpx; color: #999; margin-top: 6rpx; }
