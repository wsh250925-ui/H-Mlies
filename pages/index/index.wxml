<!-- 首页 -->
<view class="container">
  <!-- 首次使用引导 -->
  <view class="first-guide" wx:if="{{isFirstLaunch}}">
    <view class="guide-card">
      <view class="guide-icon">👋</view>
      <view class="guide-title">欢迎使用自律打卡</view>
      <view class="guide-desc">请先选择你的性别，<br/>我们将为你定制专属计划</view>
      <button class="btn btn-primary" bindtap="goToProfile">去设置</button>
    </view>
  </view>

  <!-- 正常页面 -->
  <block wx:else>
    <!-- 追踪器卡片列表 -->
    <view class="tracker-card" wx:for="{{trackers}}" wx:key="id" style="background: linear-gradient(135deg, {{item.color}}, {{item.colorLight}});">
      <!-- 头部 -->
      <view class="t-header flex-between">
        <view class="t-title">
          <text class="t-icon">{{item.icon}}</text>
          <text class="t-name">{{item.name}}</text>
        </view>
        <text class="t-subtitle">元气值</text>
      </view>

      <!-- 元气值 -->
      <view class="t-vitality-row flex-between">
        <view class="t-vitality-num">
          <text class="t-num">{{item.vitality}}</text>
          <text class="t-percent">%</text>
        </view>
        <view class="t-days-badge">
          <text>已坚持 {{item.days}} 天</text>
        </view>
      </view>

      <!-- 进度条 -->
      <view class="t-bar-wrap">
        <view class="t-bar"><view class="t-bar-fill" style="width: {{item.vitality}}%;"></view></view>
        <text class="t-bar-label">21天满</text>
      </view>

      <!-- 按钮 -->
      <view class="t-btns">
        <view class="t-btn t-btn-check {{item.checked ? 'done' : ''}}" bindtap="doCheckin" data-id="{{item.id}}">
          <text>{{item.checked ? '✅ 已打卡' : '📝 打卡'}}</text>
        </view>
        <view class="t-btn t-btn-break" bindtap="showBreak" data-id="{{item.id}}" data-name="{{item.name}}" data-vitality="{{item.vitality}}">
          <text>⚠️ 休息</text>
        </view>
      </view>

      <!-- 信息 -->
      <view class="t-info">
        <text>从 {{item.startText}} 开始</text>
        <text wx:if="{{item.longestStreak > 0}}"> · 🏆 最长 {{item.longestStreak}} 天</text>
      </view>
    </view>

    <!-- 名言轮播 -->
    <view class="quote-card">
      <view class="quote-icon">💬</view>
      <view class="quote-text {{quoteFade ? 'fade-in' : ''}}">{{quoteText}}</view>
      <view class="quote-author">—— {{quoteAuthor}}</view>
      <view class="quote-dots">
        <text class="dot {{index === currentQuote ? 'active' : ''}}" wx:for="{{quotes}}" wx:key="*this"></text>
      </view>
    </view>

    <!-- 鼓励语 -->
    <view class="encourage-card">
      <text class="encourage-text">{{encouragement}}</text>
    </view>
  </block>
</view>

<!-- 休息确认弹窗 -->
<view class="modal-mask" wx:if="{{showBreak}}">
  <view class="modal-box">
    <view class="modal-title">⚠️ 休息一天？</view>
    <view class="modal-body">
      「{{breakTarget.name}}」当前元气 <text class="text-red modal-highlight">{{breakTarget.vitality}}%</text><br/>
      确认后降至 <text class="text-red modal-highlight">{{breakTarget.after}}%</text>（-40%）
    </view>
    <view class="modal-btns">
      <button class="btn btn-sm" bindtap="hideBreak">取消</button>
      <button class="btn btn-sm btn-danger" bindtap="doBreak">确认</button>
    </view>
  </view>
</view>
