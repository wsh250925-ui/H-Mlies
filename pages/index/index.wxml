<!-- 首页 -->
<view class="container">
  <!-- 首次使用引导 -->
  <view class="first-guide" wx:if="{{isFirstLaunch}}">
    <view class="guide-card">
      <view class="guide-icon">👋</view>
      <view class="guide-title">欢迎使用自律打卡</view>
      <view class="guide-desc">请先选择你的性别，<br/>我们将为你定制专属计划</view>
      <button class="btn btn-primary" bindtap="goToProfile">去设置</button>
    </view>
  </view>

  <!-- 正常页面 -->
  <block wx:else>
    <!-- 元气值卡片 -->
    <view class="vitality-card card" style="background: linear-gradient(135deg, {{themeColor}}, {{themeLight}});">
      <view class="vitality-label">{{abstinenceLabel}} · 元气值</view>
      <view class="vitality-ring-wrap">
        <view class="vitality-ring">
          <view class="ring-bg"></view>
          <view class="ring-inner">
            <text class="vitality-number">{{vitality}}</text>
            <text class="vitality-percent">%</text>
          </view>
        </view>
      </view>
      <view class="vitality-sub">
        <text>已坚持 {{abstinenceDays}} 天</text>
      </view>
      <view class="vitality-bar-wrap">
        <view class="vitality-bar">
          <view class="vitality-bar-fill" style="width: {{vitality}}%; background: #fff;"></view>
        </view>
        <text class="vitality-bar-label">21天满元气</text>
      </view>
      <view class="vitality-info">
        <text>从 {{startDateText}} 开始</text>
        <text wx:if="{{longestStreak > 0}}"> · 🏆 最长 {{longestStreak}} 天</text>
      </view>

      <!-- 打卡 + 破戒 按钮 -->
      <view class="vitality-btns">
        <view class="vitality-btn btn-checkin {{abstinenceChecked ? 'done' : ''}}" bindtap="doCheckinAbstinence">
          <text class="vitality-btn-icon">{{abstinenceChecked ? '✅' : '📝'}}</text>
          <text class="vitality-btn-text">{{abstinenceChecked ? '已打卡' : '打卡'}}</text>
        </view>
        <view class="vitality-btn btn-break" bindtap="showBreakModal">
          <text class="vitality-btn-icon">⚠️</text>
          <text class="vitality-btn-text">破戒</text>
        </view>
      </view>
    </view>

    <!-- 名言轮播 -->
    <view class="quote-card">
      <view class="quote-icon">💬</view>
      <view class="quote-text {{quoteFade ? 'fade-in' : ''}}">{{quoteText}}</view>
      <view class="quote-author">—— {{quoteAuthor}}</view>
      <view class="quote-dots">
        <text class="dot {{index === currentQuote ? 'active' : ''}}" wx:for="{{quotes}}" wx:key="*this"></text>
      </view>
    </view>

    <!-- 今日状态卡片 -->
    <view class="card">
      <view class="card-title">今日打卡 · {{todayText}}</view>
      <view class="module-list">
        <view
          class="module-item {{item.checked ? 'checked' : ''}}"
          wx:for="{{modules}}"
          wx:key="id"
          bindtap="toggleCheckin"
          data-id="{{item.id}}"
          data-checked="{{item.checked}}"
        >
          <view class="module-icon">{{item.icon}}</view>
          <view class="module-name">{{item.name}}</view>
          <view class="module-status">
            <text wx:if="{{item.checked}}" class="text-green">✅</text>
            <text wx:else class="text-gray">⬜</text>
          </view>
        </view>
      </view>

      <!-- 无模块提示 -->
      <view class="empty-hint" wx:if="{{modules.length === 0}}">
        <text>暂无打卡模块，去</text>
        <text class="link" bindtap="goToProfile">「我的」</text>
        <text>添加吧</text>
      </view>
    </view>

    <!-- 鼓励语 -->
    <view class="encourage-card">
      <text class="encourage-text">{{encouragement}}</text>
    </view>
  </block>
</view>

<!-- 破戒确认弹窗 -->
<view class="modal-mask" wx:if="{{showBreak}}">
  <view class="modal-box">
    <view class="modal-title">⚠️ 确认破戒</view>
    <view class="modal-body">
      当前元气值 <text class="text-red modal-highlight">{{vitality}}%</text>，<br/>
      破戒后将降至 <text class="text-red modal-highlight">{{breakVitality}}%</text>（-40%）
    </view>
    <view class="modal-btns">
      <button class="btn btn-sm" bindtap="hideBreakModal">取消</button>
      <button class="btn btn-sm btn-danger" bindtap="doBreak">确认破戒</button>
    </view>
  </view>
</view>
